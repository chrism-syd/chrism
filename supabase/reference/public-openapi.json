      "get": {
        "summary": "Query shared core people records",
        "description": "Reference path only. Knights-specific fields no longer live on people.",
        "responses": {
          "200": {
            "description": "People rows",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/People"
                  }
                }
              }
            }
          }
        }
      }
    },
