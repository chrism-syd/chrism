            }
          }
        }
      }
    },
    "/rest/v1/rpc/apply_supreme_import_row": {
      "post": {
        "summary": "Apply one confirmed Supreme import row atomically",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApplySupremeImportRowInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resolved member action",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplySupremeImportRowResult"
                }
              }
            }
          },
          "400": {
            "description": "Validation or conflict error"
          },
          "409": {
            "description": "Duplicate membership conflict"
          }
        }
      }
    }
  },
